# FoxBot2Hermes 配置样例
# ---------------------------------------------------------------------------
# 部署时把需要的变量填进 ~/.hermes/.env(Hermes gateway 统一读取),
# 不是放在项目目录。留空/不写的变量用代码内默认值。
# 变量完整说明见 plugin/fox_bot/plugin.yaml 或 README「配置项速查」。
# ===========================================================================

# ---- 数据根目录 ----
# 所有持久化/临时文件的统一根目录;改这一个即可整体搬家。
# 各路径型变量(*_FILE/*_DIR/LOG_FILE 等)默认都在它下面,单独覆盖某一项时
# 可用 ${FOX_QQ_BOT_DATA_DIR} 引用(路径型变量都支持 ~ 与 ${VAR} 展开),如:
#   FOX_QQ_BOT_MEDIA_FILE=${FOX_QQ_BOT_DATA_DIR}/media_v2.json
# FOX_QQ_BOT_DATA_DIR=~/.hermes/fox_bot_data

# ---- 必填 ----
FOX_QQ_BOT_QQ=10001                 # 机器人自己的 QQ 号
FOX_QQ_BOT_ALLOWED_GROUPS=12345,67890   # 群白名单(逗号分隔),留空=不响应任何群
FOX_QQ_BOT_ADMIN_QQ=10000               # 管理员 QQ(逗号分隔);管理员始终可私聊,不受私聊白名单限制

# ---- NapCat 连接 ----
FOX_QQ_BOT_NAPCAT_WS_PORT=18197          # 本插件 OneBot v11 WS 监听端口,NapCat 反向连入
FOX_QQ_BOT_NAPCAT_WS_HOST=0.0.0.0        # 监听地址,默认全网卡
# FOX_QQ_BOT_NAPCAT_CALL_TIMEOUT=30    # NapCat API 调用超时(秒)
# 发消息遇 NapCat 内部 sendMsg 确认超时(retcode=1200)时视为已送达(默认 true),
# 避免 AI 误判失败重发导致重复消息(图片/富媒体上传慢时高发)。设 false 恢复严格报错。
# FOX_QQ_BOT_NAPCAT_SEND_TIMEOUT_AS_SUCCESS=true
# 接入鉴权 token: 对应 NapCat websocketClient 配置里的 "token"。非空时握手必须带
# Authorization: Bearer <token>(或裸 token),否则拒接;留空=不校验。
# 公网 0.0.0.0 裸监听时强烈建议设置,防他人冒充 NapCat 连入。两边的值必须一致。
FOX_QQ_BOT_NAPCAT_WS_TOKEN=              # 例: 用 `openssl rand -hex 32` 生成一段随机串

# ---- 私聊(可选) ----
# 管理员(FOX_QQ_BOT_ADMIN_QQ)永远允许私聊,无需加入此名单。
# 此名单控制普通用户是否可私聊;留空=只有管理员能私聊
FOX_QQ_BOT_ALLOWED_PRIVATE=             # 私聊白名单普通用户 QQ(逗号分隔;管理员收发均不受此限)

# ---- 好友请求自动通过 ----
# 收到加好友请求时,对方是管理员或私聊白名单用户 → 自动同意;
# 其余请求仅记日志,留待 QQ 客户端手动处理。
# 通过后延迟 FRIEND_GREET_DELAY 秒唤醒该私聊,让 AI 主动打一次招呼;
# 等待期间对方先发来消息则自动取消问候(AI 顺着消息回,不再另行打招呼)。
# FOX_QQ_BOT_FRIEND_AUTO_ACCEPT=true
# FOX_QQ_BOT_FRIEND_GREET_DELAY=60      # <=0 = 通过后不主动问候
# FOX_QQ_BOT_FRIEND_PROMPT_PATH=        # 问候提示词模版(默认插件内 prompts/friend.txt)

# ---- 触发:@别名 与关键词 ----
FOX_QQ_BOT_NAMES=酒狐               # 纯文本 @别名(手打 @ 不产生 at 段时兜底识别),逗号分隔
# 关键词触发字典(JSON),命中后按概率掷骰;骰输则落到下一渠道(消息概率)。
# 字典顺序即优先级,只取第一个命中词;大小写不敏感、子串匹配。
FOX_QQ_BOT_GROUP_KEYWORDS={"狐狸": 0.8, "女仆": 0.5, "AI": 0.3, "ai": 0.3, "机器人": 0.3, "狐": 0.1}

# ---- 群内成员级放行(一般不用动) ----
# 默认放行群白名单内所有成员触发机器人(管理员始终放行)。
# 若只想让部分人能触发(其余人的发言只作背景上下文/热度),取消注释这两行:
# FOX_QQ_BOT_GROUP_ALLOW_ALL_GROUP_USERS=false
# FOX_QQ_BOT_GROUP_ALLOWED_USERS=10000,10086   # 允许触发的群成员 QQ(管理员不在此列也始终放行)

# ---- 提示词运行时注入 ----
# 注入到每个提示词模版开头 {{INJECT}} 占位符的内容,无需改模版文件即可临时追加指令。
# FOX_QQ_BOT_INJECT_PROMPT=

# ---- 定时任务 cron ----
# JSON 列表(默认空),每项一个触发项: 到点后以 prompt 填入 cron 提示词模版
# (prompts/cron.txt 的 {{CronBody}})唤醒 target 指定的群/私聊会话。
#   name:     任务名(日志与队列去重用)
#   schedule: 5 字段 cron(分 时 日 月 周),支持 * , - / 步进;按 FOX_QQ_BOT_TIMEZONE 判定
#   prompt:   注入的任务要求文本(非空)
#   target:   "group:群号" 或 "private:QQ号"(须在白名单内;管理员私聊始终放行)
# 启动时逐项校验: cron 不可解析 / prompt 为空串 / target 非法的项不启动,
# 并在日志与管理员私聊弹出警告。
# FOX_QQ_BOT_CRON_TASKS=[{"name": "Morning feeds", "schedule": "0 9 * * *", "prompt": "Check the configured feeds and summarize anything new.", "target": "group:123456"}]
# FOX_QQ_BOT_CRON_PROMPT_PATH=           # 定时任务提示词模版路径(默认插件内 prompts/cron.txt)

# ---- 时间注入与时区 ----
# 提示词模版里的 {{TIME}} 占位符会替换成"当前时间",让酒狐知道现在几点、周几。
# 时间按下面的时区渲染(不依赖服务器系统时区),默认上海;此项默认生效(未注释)。
FOX_QQ_BOT_TIMEZONE=Asia/Shanghai        # IANA 时区名,如 America/New_York;非法则回退系统本地时间
# FOX_QQ_BOT_TIME_FORMAT=%Y-%m-%d %H:%M:%S %A   # 注入时间的 strftime 格式(默认含星期)

# ---- 触发节奏与冷却 ----
# FOX_QQ_BOT_GROUP_CTX_K=50             # 上下文队列长度(最多注入多少条历史)
# FOX_QQ_BOT_TRIGGER_QUEUE=3            # 待处理触发队列长度,满了顶掉最旧的
# FOX_QQ_BOT_PROCESS_DELAY=6            # T1 对话处理延迟(秒): 收到消息到取件至少等这么久
# FOX_QQ_BOT_BURST_DELAY=2              # T2 连续对话推迟(秒): 消息间隔<T2 就继续推迟,等停顿再回
# FOX_QQ_BOT_USER_COOLDOWN=1            # 个人冷却(秒): 同一用户连续触发的最小间隔
# FOX_QQ_BOT_GROUP_SHARED_COOLDOWN=0    # 群共享冷却(秒): 任意触发后压制概率渠道;0=关闭

# ---- 热度与概率(仅群聊) ----
# 热度衡量群的活跃程度,由两条概率渠道共用,但两渠道的曲线参数各自独立配置。
#
# 热度统计方式:
# FOX_QQ_BOT_GROUP_HEAT_WINDOW=60       # 瞬时热度统计窗口(秒),单位时间内真人发言数→条/分钟
# FOX_QQ_BOT_GROUP_HEAT_ACCUMULATE=false# 热度模式: false=瞬时速率(默认) / true=累计值 C
#
# 累计模式参数(仅 HEAT_ACCUMULATE=true 时生效):
# FOX_QQ_BOT_GROUP_HEAT_ACC_RATIO=0.2   # 每次发言 C += 瞬时速率 × 此系数
# FOX_QQ_BOT_GROUP_HEAT_MAX=100         # C 的上限,防无限累积;<=0 不设限
# FOX_QQ_BOT_GROUP_HEAT_DECAY_IDLE=40   # 最后一条真人发言后,空闲多少秒 C 开始衰减
# FOX_QQ_BOT_GROUP_HEAT_DECAY_FACTOR=0.95 # C 每秒保留的比例(0.95 ≈ 40s 后降至约 13%)
#
# 定时渠道(每隔 TIMER_INTERVAL 秒对活跃群判定一次):
# FOX_QQ_BOT_GROUP_TIMER_INTERVAL=20    # 定时判定间隔(秒);<=0 则完全关闭定时渠道
# FOX_QQ_BOT_GROUP_TIMER_PROB_LO=2      # 热度 <= 此值时概率为 0
# FOX_QQ_BOT_GROUP_TIMER_PROB_HI=20     # 热度 >= 此值时概率达到上限
# FOX_QQ_BOT_GROUP_TIMER_PROB_THRESHOLD=0.1  # 概率起跳值: rate 刚过 LO 时的最低概率(默认 0.1)
# FOX_QQ_BOT_GROUP_TIMER_PROB_CAP=1.0   # 概率上限(1.0=热群必触发)
# FOX_QQ_BOT_GROUP_TIMER_PROB_CURVE=linear  # 概率曲线: linear(默认)/quadratic/sqrt/cubic/cbrt
#
# 每条消息渠道(每条真人发言都掷一次骰):
# FOX_QQ_BOT_GROUP_MSG_PROB_LO=5		# 热度 <= 此值时概率为 0
# FOX_QQ_BOT_GROUP_MSG_PROB_HI=24		# 热度 >= 此值时概率达到上限
# FOX_QQ_BOT_GROUP_MSG_PROB_THRESHOLD=0.05    # 概率起跳值: rate 刚过 LO 时的最低概率(默认 0.05)
# FOX_QQ_BOT_GROUP_MSG_PROB_CAP=0.2     # 每条消息最高 20% 概率触发(默认 0.2)
# FOX_QQ_BOT_GROUP_MSG_PROB_CURVE=linear  # 概率曲线: linear(默认)/quadratic/sqrt/cubic/cbrt

# ---- 临时热度 TK(仅群聊,独立于上面的热度与聊天频率) ----
# 一条独立的"@热度",按次计、与一次@里有几个人无关:
#   被@一次 +TK_STEP_MENTIONED;机器人主动@别人/引用别人一次 +TK_STEP_AT_OTHERS。
# 封顶 TK_MAX,按固定频率结算衰减。取概率时按渠道乘数叠加:
#   参与概率的热度 = 基础热度 + TK × 渠道乘数(0=该渠道不受 TK 影响)。
# FOX_QQ_BOT_GROUP_TK_STEP_MENTIONED=100    # 被@一次增加的 TK
# FOX_QQ_BOT_GROUP_TK_STEP_AT_OTHERS=50     # 主动@别人/引用别人一次增加的 TK
# FOX_QQ_BOT_GROUP_TK_MAX=200               # TK 上限
# FOX_QQ_BOT_GROUP_TK_SETTLE_INTERVAL=10    # 衰减结算频率(秒),<=0 关闭衰减循环
# FOX_QQ_BOT_GROUP_TK_DECAY_PROPORTIONAL=false  # 衰减方式: false=固定值(默认) / true=比例
# FOX_QQ_BOT_GROUP_TK_DECAY_FIXED=10        # 固定衰减: 每次结算减去的值
# FOX_QQ_BOT_GROUP_TK_DECAY_RATIO=0.75      # 比例衰减: 每次结算乘以的比例
# FOX_QQ_BOT_GROUP_TK_MSG_MULT=0.1          # TK 对"每条消息渠道"概率的乘数(默认 0.1x,0=无影响)
# FOX_QQ_BOT_GROUP_TK_TIMER_MULT=1.0        # TK 对"定时渠道"概率的乘数(默认 1x,0=无影响)
# FOX_QQ_BOT_GROUP_CUT_LINE=0.1             # 比例衰减共享归零阈值(TK 与累计热度 C 共用)

# ---- 假 @名字 自动转真 @(仅群聊) ----
# AI 文本里写的 @某人 只是纯文本(不通知对方);开启后出站前自动匹配群成员,
# 按 群名片→真实昵称→QQ号 顺序精确匹配,命中则替换为真 at 段(会高亮+通知)。
# 中文无空格,@名字 边界取到空格/标点为止;匹配不到则保留原文,不误伤。
# FOX_QQ_BOT_GROUP_RESOLVE_AT=true          # 假@转真@ 总开关(默认开启)
# FOX_QQ_BOT_GROUP_MEMBER_CACHE_TTL=1800    # 群成员列表缓存 TTL(秒),默认 30 分钟
# FOX_QQ_BOT_GROUP_MEMBER_FORCE_CD=60       # @未知QQ号触发的立即强刷成员表冷却(秒)

# ---- 媒体桥接(文件/图片内部链接,不落地缓存) ----
# 消息里的文件/图片不下载到本地,只登记引用并生成内部链接注入给 AI;
# Agent 在自己的运行环境里(本机/容器)用 wget/curl 等请求该链接时才动态桥接
# 流式转发(上游直链或 NapCat 接口),本插件侧不留缓存文件。
FOX_QQ_BOT_MEDIA_PORT=18198              # 桥接 HTTP 端口
FOX_QQ_BOT_MEDIA_BIND=0.0.0.0            # 监听地址
# 注入链接使用的主机名/IP——以 Agent 的运行环境能访问到本插件为准:
#   Agent 与插件同机: 127.0.0.1;
#   Agent 在容器里跑: 换成容器可达的宿主机 IP(如 docker 默认网桥网关 172.17.0.1
#   或 host.docker.internal),否则容器内 wget 不通。
FOX_QQ_BOT_MEDIA_HOST=127.0.0.1
# FOX_QQ_BOT_MEDIA_ENABLE=true          # 总开关
# FOX_QQ_BOT_MEDIA_TTL=86400            # 登记条目过期秒数(上限 24 小时)
# FOX_QQ_BOT_MEDIA_MAX_MB=100           # 大小上限,超过标注"过大不可下载"
# FOX_QQ_BOT_MEDIA_FILE=~/.hermes/fox_bot_data/media.json  # 登记表持久化路径

# 沙盒容器取文件: AI 终端沙盒里生成的本地文件,宿主机找不到时按候选容器
# docker cp 取回再发送(临时文件用完即删)。默认 auto: 用 Hermes 官方标签
# label=hermes-agent=1 精准过滤会话沙盒容器(排除 napcat/数据库等无关容器;
# 对话侧终端就在宿主机、无此类容器时过滤为空,自动降级不影响)。
# 其他取值: hermes=同 auto;all=全部运行中容器(兜底);off/空=关闭只查宿主机;
# 也可给逗号分隔的容器名/ID/通配(fnmatch,如 mybox-*)。需 gateway 用户有 docker 权限。
# FOX_QQ_BOT_SANDBOX_CONTAINERS=auto
# 手动限定沙盒容器(名字或 ID)。设了只认它;没设且发现多个容器时,
# 文件取回/生图注入一律拒绝并提示配置本项(防止落错容器)。
# FOX_QQ_BOT_DOCKER_CONTAINER_SELECT=
# FOX_QQ_BOT_SANDBOX_FETCH_TIMEOUT=15

# ---- 出站协议 ----
# 双通道发言: fox_qq_send_message 工具是首选出口;下面开启时 AI 的正文(碎碎念)
# 也即时代发到当前会话。默认开(注释=用默认值)。
# - 开: 正文即到即代发(过滤 [CONTINUE_THINK] 标记本身、保留内容);收尾时最后一段
#   不是 [NO_REPLY]/[CONTINUE_THINK] 就温和提醒补结束标记(不算错误、不报发送失败);
# - 关: 正文不代发也不报错,收尾时告知发送失败、要求改用工具重发(旧纠正流程)。
# FOX_QQ_BOT_CHATTER_AUTOSEND=true
# FOX_QQ_BOT_PROTOCOL_RETRY=3           # 收尾提醒/纠正上限(默认 3,上限 3,超限强制结束回合)
# gateway 系统通知(home channel 引导/任务打断/进度心跳等)会经 send() 下发,含以下
# 子串的裸回复直接忽略(不发 QQ、不算违规)。JSON 字符串列表,整体覆盖默认值。
# FOX_QQ_BOT_GATEWAY_NOTICE_MARKERS=["No home channel is set", "/sethome", "Interrupting current task", "receiving stream response", "Credit access restored", "⏳ Working"]
# FOX_QQ_BOT_CONTINUE_THINK_MAX=100     # [CONTINUE_THINK] 续想次数上限(独立计数,<=0 不限;每次成功续想重置纠正容错)
# FOX_QQ_BOT_TURN_TIMEOUT=500           # 回合超时兜底(秒): 等不到 NO_REPLY 时强制结束
# 回合超时通知附带"回合轨迹": USER 递交/AI 回答/工具调用及成败
# (不含 AI 思考与工具详细输出);太长时丢最旧条目,仍超限则完全不附带。
# FOX_QQ_BOT_TIMEOUT_TRACE_MAX_ITEMS=12   # 轨迹最多保留最近多少条
# FOX_QQ_BOT_TIMEOUT_TRACE_MAX_CHARS=1500 # 轨迹文本超过此字数则不输出;<=0 关闭轨迹

# ---- 错误通知 ----
# 运行时错误(异常/回合超时/纠正耗尽)的通知渠道;完整堆栈始终进日志。
# FOX_QQ_BOT_ERROR_NOTIFY_ADMIN=true    # 私聊通知所有管理员(默认开启)
# FOX_QQ_BOT_ERROR_NOTIFY_GROUP=false   # 在出错的群里通知(默认关闭,避免打扰)
# FOX_QQ_BOT_ERROR_NOTIFY_COOLDOWN=60   # 同类错误通知冷却(秒),防刷屏

# ---- 状态持久化 ----
# FOX_QQ_BOT_STATE_FILE=~/.hermes/fox_bot_data/groups.json  # 持久化文件路径
# FOX_QQ_BOT_STATE_SAVE_INTERVAL=30     # 自动落盘间隔(秒);退出时始终落盘;0=关闭自动落盘
# FOX_QQ_BOT_TMP_DIR=~/.hermes/fox_bot_data/tmp  # 插件临时目录(沙盒取回/生图中转;启动时自动清空残留)

# ---- 输出 ----
# FOX_QQ_BOT_IMAGE_URL_AS_IMAGE=true    # 回复文本中的图片 URL 自动转为 QQ 图片消息
# FOX_QQ_BOT_MAX_SEGMENT_LEN=1800       # 单条 QQ 消息最大字符数
# FOX_QQ_BOT_MAX_SEGMENTS=3             # 长回复最多分几条发送(超出截断)

# ---- 日志 ----
# 不设 FOX_QQ_BOT_LOG_FILE 时,日志混入 gateway 主日志(用 grep fox_bot 过滤)。
# FOX_QQ_BOT_LOG_FILE=~/.hermes/fox_bot_data/fox_bot.log   # 独立日志文件路径
# FOX_QQ_BOT_LOG_LEVEL=INFO             # 独立日志级别: DEBUG / INFO / WARNING
# FOX_QQ_BOT_LOG_MAX_MB=10              # 日志文件大小上限(MB): 超过时砍掉前半保留后半; 0=不限
# FOX_QQ_BOT_LOG_PROPAGATE=true         # 写独立文件时是否同时输出到 gateway 主日志

# ---- 调试开关 ----
# 以下开关打 INFO/DEBUG 级日志,开启后在独立日志或 gateway 主日志里都能看到。
# FOX_QQ_BOT_DEBUG_HEAT=false           # 每次热度变化(累加/衰减前后值)
# FOX_QQ_BOT_DEBUG_TRIGGER=false        # 每次概率判定(含命中但骰输、未触发)
# FOX_QQ_BOT_DEBUG_CTX=false            # 上下文队列(入队/注入长度,全文需 DEBUG_PROMPT)
# FOX_QQ_BOT_DEBUG_TOOL=false           # 工具调用解析(工具名/chat_id/参数键)
# FOX_QQ_BOT_DEBUG_WS=false             # WebSocket 原始帧(收发完整 JSON,量大)
# FOX_QQ_BOT_DEBUG_API=false            # OneBot API 调用(action/params/响应结果)
# FOX_QQ_BOT_DEBUG_MEDIA=false          # 媒体桥接(图片/文件登记与拒绝)
# FOX_QQ_BOT_DEBUG_PROMPT=false         # 每次注入 Agent 的提示词全文(量大)
# FOX_QQ_BOT_DEBUG_REPLY=false          # 出站消息(分段/引用/表情发送细节)
# FOX_QQ_BOT_DEBUG_EMOTICON=false       # 表情解析(命中枚举/回退路径/URL/模糊匹配)

# ---- 通用生图(默认全空 = 功能关闭,不注册工具) ----
# 任一方案填了 API_KEY 即启用;KEY 有但缺必要参数 = 配置错误(启动告警,该方案不生效)。
# 图片保存目录不是配置项: AI 调工具时按它自己的文件系统指定,
# 容器后端(沙盒)下生成结果自动放进容器;文件名自动生成、重名自动改名。
# 统一强制关水印(豆包 watermark=false;GPT-image 本无可见水印)。
# FOX_QQ_BOT_IMAGE_OPENAI_API_KEY=
# FOX_QQ_BOT_IMAGE_OPENAI_BASE_URL=https://api.openai.com/v1   # 中转商可改
# FOX_QQ_BOT_IMAGE_OPENAI_MODEL=gpt-image-2
# FOX_QQ_BOT_IMAGE_OPENAI_DEFAULT_SIZE=auto   # 缺省分辨率(AI 可按次覆盖);auto/1024x1024/1536x1024/1024x1536/宽x高。旧名 _SIZE 仍兼容
# FOX_QQ_BOT_IMAGE_OPENAI_REF=false     # 参考图(图生图)开关,默认关(走 /images/edits)
# FOX_QQ_BOT_IMAGE_DOUBAO_API_KEY=
# FOX_QQ_BOT_IMAGE_DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# FOX_QQ_BOT_IMAGE_DOUBAO_MODEL=        # 方舟模型号必填
# FOX_QQ_BOT_IMAGE_DOUBAO_DEFAULT_SIZE=1K     # 缺省分辨率(AI 可按次覆盖);1K/2K/宽x高。旧名 _SIZE 仍兼容
# FOX_QQ_BOT_IMAGE_DOUBAO_REF=false     # 参考图开关,默认关(走 image 参数)
# FOX_QQ_BOT_IMAGE_DEFAULT=             # 两家都配时指定默认方案(openai/doubao),不配则告警并取第一个
# FOX_QQ_BOT_IMAGE_TIMEOUT=120          # 生图请求超时秒

# ---- 可选工具开关(OCR / STT) ----
# OCR: 本地识别图片文字(NapCat 的 QQ 自带 OCR 仅 Windows 可用,已弃用)。
# 默认关;后端二选一: tesseract(默认,CLI 子进程零常驻内存,沙盒模式在
# 容器内跑,需容器装 tesseract-ocr + 语言包)/ rapidocr(ONNX,精度更高
# 但常驻 300-500MB 内存,需 pip install rapidocr-onnxruntime 进 gateway venv)。
# FOX_QQ_BOT_TOOL_OCR=false
# 后端三选一: tesseract(默认)/ rapidocr / napcat(QQ 自带,仅 Windows 端 NapCat 可用,Linux 会超时)。
# FOX_QQ_BOT_OCR_BACKEND=tesseract
# FOX_QQ_BOT_OCR_TESSERACT_LANG=chi_sim+eng
# STT: 语音转文字(QQ 自带接口,无额外依赖),默认开。
# FOX_QQ_BOT_TOOL_STT=true
